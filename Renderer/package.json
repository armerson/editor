{
  "name": "football-highlight-reel",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "build": "tsc",
    "render": "remotion render src/index.ts HighlightReel",
    "render:landscape": "remotion render src/index.ts HighlightReel --props='{\"presetId\":\"landscape\"}'",
    "render:square": "remotion render src/index.ts HighlightReel --props='{\"presetId\":\"square\"}'",
    "render:vertical": "remotion render src/index.ts HighlightReel --props='{\"presetId\":\"vertical\"}'",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/lambda": "^4.0.0",
    "@remotion/eslint-config": "^4.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
