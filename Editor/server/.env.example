PORT=3001
PUBLIC_BASE_URL=http://localhost:3001

# Where rendered MP4s are written before upload
RENDERS_DIR=./renders

# Remotion renderer project — MUST be an absolute path.
# Relative paths are resolved from wherever the process starts, which is unreliable.
# Example: REMOTION_ROOT=/home/user/highlight-reel-system/Renderer
REMOTION_ROOT=
REMOTION_COMPOSITION_ID=HighlightReel

# Optional: upload output MP4 to a bucket
# If unset, server will serve local files under /renders/
RENDER_OUTPUT_BUCKET=
RENDER_OUTPUT_PREFIX=renders

# Optional: if you use a CDN / custom domain for your bucket objects
RENDER_OUTPUT_PUBLIC_BASE_URL=
