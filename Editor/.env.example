# Firebase (optional). Copy to .env and fill in your project values.
# Without these, media uses local blob URLs (no persistence across sessions).
# Get these from Firebase Console > Project settings > General > Your apps.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend render API URL (set to Railway/Render.com URL in production)
VITE_RENDER_API_BASE=http://localhost:3001

# Beta access token — shown to testers; gates the UI and authenticates API calls.
# Leave empty to disable the gate (local dev / open access).
VITE_BETA_TOKEN=
